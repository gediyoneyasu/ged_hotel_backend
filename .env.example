# MongoDB Atlas (required in production: NODE_ENV=production)
MONGO_URI=

# Public site URL (Vercel), used for Chapa return/callback when Origin is missing
FRONTEND_URL=https://your-app.vercel.app

# Optional: extra allowed CORS origins (comma-separated), e.g. preview deploys
# ALLOWED_ORIGINS=https://branch-name.vercel.app

# Chapa
CHAPA_SECRET_KEY=

# Optional: shown in startup logs only
# PUBLIC_URL=https://your-api.onrender.com
